# MongoDB Connection String
MONGOURL=mongodb+srv://username:password@cluster.mongodb.net/?appName=toolsAmertak

# JWT Secret (keep secure!)
JWT_SECRET=your_super_secret_key_here_change_in_production

# OpenAI API Key (for transcription feature)
OPENAI_API_KEY=sk-your-api-key-here

# YT-DLP Path (optional - if yt-dlp is not in PATH)
YTDLP_PATH=yt-dlp

# Environment
NODE_ENV=production

# Port (Render will automatically set this)
PORT=3001
